generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Question {
  id              Int      @id @default(autoincrement())
  qNumber         String   @unique
  text            String
  category        String   // BZF1, BZF2, Both
  imageUrl        String?
  answers         Answer[]
  stats           UserStat[]
  examQuestions   ExamQuestion[]
}

model Answer {
  id          Int      @id @default(autoincrement())
  questionId  Int
  text        String
  isCorrect   Boolean
  question    Question @relation(fields: [questionId], references: [id])
}

model Account {
  id        Int      @id @default(autoincrement())
  guid      String   @unique @default(uuid())
  name      String
  createdAt DateTime @default(now())
  
  userStats   UserStat[]
  textStats   TextStat[]
  examResults ExamResult[]
}

model UserStat {
  id          Int      @id @default(autoincrement())
  accountId   Int?
  questionId  Int
  correct     Int      @default(0)
  incorrect   Int      @default(0)
  isDifficult Boolean  @default(false)
  question    Question @relation(fields: [questionId], references: [id])
  account     Account? @relation(fields: [accountId], references: [id], onDelete: Cascade)
  @@unique([accountId, questionId])
}

model Exam {
  id        Int      @id @default(autoincrement())
  name      String
  examQuestions ExamQuestion[]
  results   ExamResult[]
}

model ExamQuestion {
  id         Int      @id @default(autoincrement())
  examId     Int
  questionId Int
  exam       Exam     @relation(fields: [examId], references: [id])
  question   Question @relation(fields: [questionId], references: [id])
}

model ExamResult {
  id        Int      @id @default(autoincrement())
  accountId Int?
  examId    Int
  date      DateTime @default(now())
  score     Int
  exam      Exam     @relation(fields: [examId], references: [id])
  account   Account? @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model BzfText {
  id        Int      @id @default(autoincrement())
  number    String   @unique
  textEn    String
  textDe    String
  stats     TextStat[]
}

model TextStat {
  id          Int      @id @default(autoincrement())
  accountId   Int?
  textId      Int
  difficulty  String   @default("unknown") // easy, medium, hard
  isFavorite  Boolean  @default(false)
  viewCount   Int      @default(0)
  easyCount   Int      @default(0)
  mediumCount Int      @default(0)
  hardCount   Int      @default(0)
  bzfText     BzfText  @relation(fields: [textId], references: [id])
  account     Account? @relation(fields: [accountId], references: [id], onDelete: Cascade)
  @@unique([accountId, textId])
}


